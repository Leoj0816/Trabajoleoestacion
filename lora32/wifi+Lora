// ==================== OBJETOS ====================
WiFiClientSecure espClient;
PubSubClient mqttClient(espClient);
Adafruit_SSD1306 display(128, 64, &Wire, -1);

DFRobot_EnvironmentalSensor environment(SEN050X_DEFAULT_DEVICE_ADDRESS, &Wire);
DFRobot_AirQualitySensor particle(&Wire, 0x19);
bool particleOK = false;

int windDirectionPin = 35;
int windSpeedPin     = 14;
int rainfallPin      = 15;
SFEWeatherMeterKit weatherMeterKit(windDirectionPin, windSpeedPin, rainfallPin);

// ==================== VARIABLES TTN ====================
unsigned long ultimoEnvioTTN = 0;
const unsigned long intervaloTTN = 1UL * 60UL * 1000UL;  // 1 minuto
float lluviaInicioIntervalo = 0.0;

void connectWiFi() {
  Serial.print("Conectando WiFi...");
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println(" WiFi OK");
}

void connectAWS() {
  espClient.setCACert(AWS_CERT_CA);
  espClient.setCertificate(AWS_CERT_CRT);
  espClient.setPrivateKey(AWS_CERT_PRIVATE);
  mqttClient.setServer(AWS_ENDPOINT, AWS_PORT);

  Serial.print("Conectando AWS IoT...");
  while (!mqttClient.connected()) {
    if (mqttClient.connect("LilyGO-Estacion-Tulua")) {
      Serial.println(" AWS OK");
    } else {
      Serial.print(".");
      delay(2000);
    }
  }
}

void publishAWS(float t, float h, float uv, float lux, float p,
                uint16_t pm1, uint16_t pm25, uint16_t pm10,
                float dir, float vel, float rain) {
  String json = "{";
  json += "\"temp\":"       + String(t, 1) + ",";
  json += "\"hum\":"        + String(h, 1) + ",";
  json += "\"uv\":"         + String(uv, 2) + ",";
  json += "\"lux\":"        + String(lux, 0) + ",";
  json += "\"presion\":"    + String(p, 1) + ",";
  json += "\"pm1\":"        + String(pm1) + ",";
  json += "\"pm25\":"       + String(pm25) + ",";
  json += "\"pm10\":"       + String(pm10) + ",";
  json += "\"viento_dir\":" + String(dir, 0) + ",";
  json += "\"viento_vel\":" + String(vel, 1) + ",";
  json += "\"lluvia\":"     + String(rain, 2);
  json += "}";

  if (mqttClient.publish(AWS_TOPIC, json.c_str())) {
    Serial.println("Enviado a AWS IoT");
  }
}

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  // OLED
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay(); display.setTextSize(1); display.setTextColor(WHITE);
  display.setCursor(0,0); display.println("Iniciando..."); display.display();

  connectWiFi();
  connectAWS();

  // Sensores
  while (environment.begin() != 0) delay(1000);
  if (particle.begin()) particleOK = true;
#ifdef SFE_WMK_PLAFTORM_UNKNOWN
  weatherMeterKit.setADCResolutionBits(12);
#endif
  weatherMeterKit.begin();

  // TTN LoRaWAN (tu config.h)
  int16_t state = node.activateOTAA();
  while (state != RADIOLIB_LORAWAN_NEW_SESSION) {
    Serial.printf("JOIN falló (%d), reintentando...\n", state);
    delay(15000);
    state = node.activateOTAA();
  }
  Serial.println("JOIN TTN OK");

  lluviaInicioIntervalo = weatherMeterKit.getTotalRainfall();

  display.clearDisplay(); display.setCursor(0,0);
  display.println("TTN + AWS OK"); display.display();
}

void loop() {
  if (!mqttClient.connected()) connectAWS();
  mqttClient.loop();

  // Lectura sensores
  float temp = environment.getTemperature(TEMP_C);
  float hum  = environment.getHumidity();
  float uv   = max(environment.getUltravioletIntensity(), 0.0f);
  float lux  = environment.getLuminousIntensity();
  float press = environment.getAtmospherePressure(HPA);

  uint16_t pm1 = 0, pm25 = 0, pm10 = 0;
  if (particleOK) {
    pm1  = particle.gainParticleConcentration_ugm3(PARTICLE_PM1_0_ATMOSPHERE);
    pm25 = particle.gainParticleConcentration_ugm3(PARTICLE_PM2_5_ATMOSPHERE);
    pm10 = particle.gainParticleConcentration_ugm3(PARTICLE_PM10_ATMOSPHERE);
  }

  float dir = weatherMeterKit.getWindDirection();
  float vel = weatherMeterKit.getWindSpeed();
  float rainTotal = weatherMeterKit.getTotalRainfall();

  // OLED
  display.clearDisplay(); display.setCursor(0,0);
  display.print("T:"); display.print(temp,1); display.println("C");
  display.print("H:"); display.print(hum,0); display.println("%");
  display.print("P:"); display.print(press,0); display.println("hPa");
  display.print("V:"); display.print(vel,1); display.println("kmh");
  display.display();

  // ENVÍO DOBLE CADA MINUTO
  if (millis() - ultimoEnvioTTN >= intervaloTTN) {
    float lluviaIntervalo = rainTotal - lluviaInicioIntervalo;

    // === ENVÍO POR LORAWAN A TTN ===
    uint8_t payload[20] = {0};
    int16_t  t = round(temp * 10);   payload[0] = highByte(t); payload[1]  = lowByte(t);
    payload[2] = round(hum * 2);
    uint16_t p = round(press * 10);  payload[3] = highByte(p); payload[4]  = lowByte(p);
    uint16_t w = round(vel * 10);    payload[5] = highByte(w); payload[6]  = lowByte(w);
    uint16_t d = round(dir);         payload[7] = highByte(d); payload[8]  = lowByte(d);
    uint16_t r = round(lluviaIntervalo * 100); payload[9]  = highByte(r); payload[10] = lowByte(r);
    uint16_t u = round(uv * 100);    payload[11] = highByte(u); payload[12] = lowByte(u);
    uint16_t l = round(lux);         payload[13] = highByte(l); payload[14] = lowByte(l);
    payload[15] = constrain(pm1, 0, 255);
    payload[16] = constrain(pm25, 0, 255);
    payload[17] = constrain(pm10, 0, 255);

    int16_t state = node.sendReceive(payload, sizeof(payload), 0, true); // unconfirmed
    Serial.println(state < 0 ? "Error TTN" : "Enviado a TTN");

    // === ENVÍO POR WiFi A AWS ===
    publishAWS(temp, hum, uv, lux, press, pm1, pm25, pm10, dir, vel, lluviaIntervalo);

    lluviaInicioIntervalo = rainTotal;
    ultimoEnvioTTN = millis();
  }

  delay(2000);
}
