/*********************************************************************
  Estación Meteorológica Completa + TTN (OTAA) - Envío CADA 5 MINUTOS
  Con estimación de velocidad del viento y lluvia si sensores fallan
*********************************************************************/

#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include "config.h"
#include "DFRobot_EnvironmentalSensor.h"
#include "DFRobot_AirQualitySensor.h"
#include "SparkFun_Weather_Meter_Kit_Arduino_Library.h"

// -------------------- RadioLib LoRaWAN --------------------
#include <RadioLib.h>
#include "config.h"

// -------------------- Configuración OLED --------------------
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_ADDR 0x3C
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// -------------------- Sensores DFRobot --------------------
DFRobot_EnvironmentalSensor environment(SEN050X_DEFAULT_DEVICE_ADDRESS, &Wire);
#define SEN0460_ADDR 0x19
DFRobot_AirQualitySensor particle(&Wire, SEN0460_ADDR);

// -------------------- Sensor meteorológico DS-15901 --------------------
int windDirectionPin = 35;   // ADC - Veleta
int windSpeedPin     = 14;   // Digital - Anemómetro
int rainfallPin      = 15;   // Digital - Pluviómetro
SFEWeatherMeterKit weatherMeterKit(windDirectionPin, windSpeedPin, rainfallPin);

// -------------------- Variables globales para envío TTN --------------------
unsigned long ultimoEnvioTTN = 0;
const unsigned long intervaloTTN = 5UL * 60UL * 1000UL;  // CADA 5 MINUTOS

float lluviaInicioIntervalo = 0.0;

// Variables para estimación
static float pressAnterior = 0.0;
static float tempAnterior = 0.0;
bool usandoEstimacionViento = false;
bool usandoEstimacionLluvia = false;
uint8_t contSinLluvia = 0;  // Contador de intervalos sin lluvia medida

// Estimación velocidad viento
float estimarVelocidadViento(float temp, float hum, float press, float uv, float lux) {
  if (pressAnterior == 0.0) return 5.0;
  float deltaPress = abs(press - pressAnterior);
  float conveccion = max(temp - 20.0, 0.0) * (1.0 - hum / 100.0);
  float solar = (uv + lux / 1000.0);
  float estimada = 3.0 + (deltaPress * 4.0) + (conveccion * 0.3) + (solar * 0.4);
  return constrain(estimada, 0.0, 35.0);
}

// Estimación lluvia (muy conservadora)
float estimarLluvia(float temp, float hum, float press, float uv) {
  if (pressAnterior == 0.0 || tempAnterior == 0.0) return 0.0;

  float deltaPress = pressAnterior - press;  // Bajada de presión = lluvia probable
  float deltaTemp = tempAnterior - temp;    // Bajada de temperatura = lluvia
  float nubosidad = (100.0 - uv * 10.0);    // Menos UV = más nubes

  float probabilidad = 0.0;
  if (hum > 85.0) probabilidad += 0.4;
  if (deltaPress > 0.5) probabilidad += 0.6;   // Bajada rápida de presión
  if (deltaTemp > 0.3) probabilidad += 0.3;    // Enfriamiento rápido
  if (nubosidad > 60.0) probabilidad += 0.3;

  // Estimación conservadora: 0.1 a 1.0 mm por 5 minutos
  return probabilidad > 0.8 ? constrain(probabilidad - 0.5, 0.1, 1.0) : 0.0;
}

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println(F("❌ Error OLED"));
    for (;;);
  }
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.println("Iniciando...");
  display.display();

  while (environment.begin() != 0) delay(1000);
  Serial.println("✅ SEN0501 OK");

  int intentos = 0;
  while (!particle.begin() && intentos < 5) {
    delay(1000);
    intentos++;
  }
  if (particle.begin()) Serial.println("✅ SEN0460 OK");

#ifdef SFE_WMK_PLAFTORM_UNKNOWN
  weatherMeterKit.setADCResolutionBits(12);
#endif
  weatherMeterKit.begin();
  Serial.println("✅ Weather Meter OK");

  // LoRaWAN JOIN (tu config.h)
  int16_t state = radio.begin();
  if (state != RADIOLIB_ERR_NONE) while (true);
  state = node.beginOTAA(joinEUI, devEUI, nwkKey, appKey);
  if (state != RADIOLIB_ERR_NONE) while (true);

  while (true) {
    state = node.activateOTAA();
    if (state == RADIOLIB_LORAWAN_NEW_SESSION) {
      Serial.println(F("✅ ¡JOIN exitoso!"));
      break;
    }
    delay(15000);
  }

  lluviaInicioIntervalo = weatherMeterKit.getTotalRainfall();

  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("Todo OK + TTN 5min");
  display.display();
  delay(2000);
}

void loop() {
  float tempC = environment.getTemperature(TEMP_C);
  float hum   = environment.getHumidity();
  float uv    = max(environment.getUltravioletIntensity(), 0.0f);
  float lux   = environment.getLuminousIntensity();
  float press = environment.getAtmospherePressure(HPA);

  uint16_t PM1_0 = 0, PM2_5 = 0, PM10 = 0;
  if (particle.begin()) {
    PM1_0 = particle.gainParticleConcentration_ugm3(PARTICLE_PM1_0_ATMOSPHERE);
    PM2_5 = particle.gainParticleConcentration_ugm3(PARTICLE_PM2_5_ATMOSPHERE);
    PM10  = particle.gainParticleConcentration_ugm3(PARTICLE_PM10_ATMOSPHERE);
  }

  float windDir = weatherMeterKit.getWindDirection();
  float windSpdMedida = weatherMeterKit.getWindSpeed();
  float rainTotal = weatherMeterKit.getTotalRainfall();

  // Inicializar históricos primera vez
  if (pressAnterior == 0.0) pressAnterior = press;
  if (tempAnterior == 0.0) tempAnterior = tempC;

  // Estimación viento
  float windSpd = windSpdMedida;
  usandoEstimacionViento = false;
  if (windSpdMedida < 1.0) {
    windSpd = estimarVelocidadViento(tempC, hum, press, uv, lux);
    usandoEstimacionViento = true;
  }

  // Estimación lluvia
  float lluviaNueva = rainTotal - lluviaInicioIntervalo;
  usandoEstimacionLluvia = false;

  if (lluviaNueva <= 0.0) {
    contSinLluvia++;
    if (contSinLluvia >= 3) {  // 3 intervalos sin lluvia medida → posible fallo o lluvia muy fina
      float estimada = estimarLluvia(tempC, hum, press, uv);
      if (estimada > 0.0) {
        lluviaNueva = estimada;
        usandoEstimacionLluvia = true;
      }
    }
  } else {
    contSinLluvia = 0;  // Reset contador si mide lluvia
  }

  // Actualizar históricos
  pressAnterior = press;
  tempAnterior = tempC;

  // Mostrar en Serial
  Serial.println("===== SEN0501 =====");
  Serial.printf("Temp: %.2f°C | Hum: %.2f%% | UV: %.2f | Luz: %.0f lx | Pres: %.1f hPa\n", tempC, hum, uv, lux, press);
  if (particle.begin()) {
    Serial.println("===== SEN0460 =====");
    Serial.printf("PM1.0: %u | PM2.5: %u | PM10: %u µg/m³\n", PM1_0, PM2_5, PM10);
  }
  Serial.println("===== DS-15901 =====");
  Serial.printf("Dir: %.1f° | Vel: %.2f km/h %s | Lluvia intervalo: %.2f mm %s\n",
                windDir, windSpd, usandoEstimacionViento ? "(estimada)" : "(medida)",
                lluviaNueva, usandoEstimacionLluvia ? "(estimada)" : "(medida)");

  // OLED
  display.clearDisplay();
  display.setCursor(0, 0);
  display.println(" Weather Station");
  display.print("T: "); display.print(tempC, 1); display.println(" C");
  display.print("H: "); display.print(hum, 0); display.println(" %");
  display.print("P: "); display.print(press, 0); display.println(" hPa");
  display.print("V: "); display.print(windSpd, 1);
  if (usandoEstimacionViento) display.print("*");
  display.println(" km/h");
  display.print("Lluvia: "); display.print(lluviaNueva, 2);
  if (usandoEstimacionLluvia) display.print("*");
  display.println(" mm");
  display.display();

  // Envío a TTN cada 5 minutos
  if (millis() - ultimoEnvioTTN >= intervaloTTN) {
    uint8_t payload[20] = {0};

    int16_t temp10 = round(tempC * 10); payload[0] = highByte(temp10); payload[1] = lowByte(temp10);
    payload[2] = round(hum * 2);
    uint16_t pres10 = round(press * 10); payload[3] = highByte(pres10); payload[4] = lowByte(pres10);
    uint16_t wind10 = round(windSpd * 10); payload[5] = highByte(wind10); payload[6] = lowByte(wind10);
    uint16_t dir = round(windDir); payload[7] = highByte(dir); payload[8] = lowByte(dir);
    uint16_t rain100 = round(lluviaNueva * 100); payload[9] = highByte(rain100); payload[10] = lowByte(rain100);
    uint16_t uv100 = round(uv * 100); payload[11] = highByte(uv100); payload[12] = lowByte(uv100);
    uint16_t luz = round(lux); payload[13] = highByte(luz); payload[14] = lowByte(luz);
    payload[15] = constrain(PM1_0, 0, 255);
    payload[16] = constrain(PM2_5, 0, 255);
    payload[17] = constrain(PM10, 0, 255);

    Serial.println(F("\n📡 Enviando a TTN (cada 5 min)..."));
    int16_t state = node.sendReceive(payload, sizeof(payload));

    if (state < RADIOLIB_ERR_NONE) {
      Serial.printf("❌ Error envío: %d\n", state);
    } else {
      Serial.println("✅ Uplink enviado correctamente");
    }

    lluviaInicioIntervalo = rainTotal;
    ultimoEnvioTTN = millis();
  }

  delay(2000);
}
